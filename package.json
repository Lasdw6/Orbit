{
  "name": "orbit",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@orbit/mobile",
    "mobile:android": "npm run android --workspace=@orbit/mobile",
    "mobile:ios": "npm run ios --workspace=@orbit/mobile",
    "web:dev": "npm run dev --workspace=@orbit/web",
    "web:build": "npm run build --workspace=@orbit/web",
    "web:preview": "npm run preview --workspace=@orbit/web"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
