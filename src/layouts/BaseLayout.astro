---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Orbit is a private personal CRM for remembering people, notes, and follow-ups.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #08111f;
        --bg-alt: #0f1d31;
        --card: rgba(13, 24, 43, 0.72);
        --card-strong: rgba(15, 28, 49, 0.92);
        --line: rgba(179, 210, 255, 0.16);
        --line-strong: rgba(179, 210, 255, 0.26);
        --text: #f6f8ff;
        --muted: #a9b8d5;
        --accent: #8dc4ff;
        --accent-strong: #b8e1ff;
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
        --radius: 28px;
        --max: 1120px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(89, 127, 255, 0.22), transparent 34%),
          radial-gradient(circle at 85% 16%, rgba(94, 210, 255, 0.14), transparent 22%),
          linear-gradient(180deg, #0b1324 0%, #08111f 48%, #091427 100%);
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          radial-gradient(circle at 18% 30%, rgba(255, 255, 255, 0.55) 0 1px, transparent 1.5px),
          radial-gradient(circle at 66% 18%, rgba(255, 255, 255, 0.35) 0 1px, transparent 1.5px),
          radial-gradient(circle at 80% 68%, rgba(255, 255, 255, 0.3) 0 1px, transparent 1.5px),
          radial-gradient(circle at 40% 78%, rgba(255, 255, 255, 0.26) 0 1px, transparent 1.5px);
        opacity: 0.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .shell {
        position: relative;
        z-index: 1;
      }

      .container {
        width: min(calc(100% - 32px), var(--max));
        margin: 0 auto;
      }

      .site-header {
        padding: 22px 0 0;
      }

      .site-header .container,
      .site-footer .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .brand img {
        width: 42px;
        height: 42px;
        filter: drop-shadow(0 0 28px rgba(120, 150, 255, 0.28));
      }

      .nav {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 6px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(10, 18, 33, 0.66);
        backdrop-filter: blur(14px);
      }

      .nav a {
        padding: 10px 16px;
        border-radius: 999px;
        color: var(--muted);
        transition: background-color 180ms ease, color 180ms ease;
      }

      .nav a:hover,
      .nav a:focus-visible {
        background: rgba(141, 196, 255, 0.12);
        color: var(--text);
      }

      main {
        padding: 34px 0 72px;
      }

      .panel {
        background: linear-gradient(180deg, rgba(16, 29, 50, 0.88), rgba(10, 19, 34, 0.92));
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .site-footer {
        padding: 0 0 28px;
      }

      .footer-copy {
        color: var(--muted);
        font-size: 0.95rem;
      }

      @media (max-width: 720px) {
        .site-header .container,
        .site-footer .container {
          flex-direction: column;
          align-items: flex-start;
        }

        .nav {
          flex-wrap: wrap;
        }

        main {
          padding-top: 22px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="container">
          <a class="brand" href="/">
            <img src="/orbit-logo.svg" alt="Orbit logo" />
            <span>Orbit</span>
          </a>
          <nav class="nav" aria-label="Main navigation">
            <a href="/">Home</a>
            <a href="/privacy">Privacy</a>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container">
          <div class="footer-copy">Orbit by Lasdw</div>
          <div class="footer-copy">Local-first relationship memory, without the noise.</div>
        </div>
      </footer>
    </div>
  </body>
</html>
