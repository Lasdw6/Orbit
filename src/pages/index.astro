---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Orbit"
  description="Orbit is coming soon to Google Play and the App Store."
>
  <style>
    .coming-soon {
      display: grid;
      place-items: center;
      min-height: calc(100vh - 180px);
    }

    .card {
      width: min(100%, 760px);
      padding: 44px 36px 36px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -120px auto auto 50%;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      transform: translateX(-50%);
      background: radial-gradient(circle, rgba(117, 135, 255, 0.16), transparent 62%);
      pointer-events: none;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border: 1px solid var(--line-strong);
      border-radius: 999px;
      background: rgba(128, 160, 255, 0.08);
      color: #d9e5ff;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .badge::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #b6c8ff;
      box-shadow: 0 0 18px rgba(182, 200, 255, 0.9);
    }

    .mark {
      width: 168px;
      height: 168px;
      margin: 26px auto 22px;
      padding: 22px;
      border: 1px solid rgba(170, 196, 255, 0.16);
      border-radius: 32px;
      background:
        radial-gradient(circle at 32% 28%, rgba(255, 255, 255, 0.08), transparent 20%),
        linear-gradient(180deg, rgba(14, 22, 39, 0.96), rgba(9, 14, 24, 0.94));
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.02) inset,
        0 30px 70px rgba(0, 0, 0, 0.34);
    }

    .mark img {
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 0 30px rgba(130, 140, 255, 0.16));
    }

    h1 {
      max-width: 9ch;
      margin: 0 auto;
      font-size: clamp(3.2rem, 8vw, 5.4rem);
      line-height: 0.9;
      letter-spacing: -0.055em;
    }

    .lede {
      max-width: 34rem;
      margin: 18px auto 0;
      color: var(--muted);
      font-size: 1.08rem;
    }

    .stores {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 26px;
    }

    .store-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      border: 1px solid rgba(183, 206, 255, 0.18);
      background: rgba(255, 255, 255, 0.04);
      color: #e9f0ff;
      font-weight: 700;
    }

    .subcopy {
      margin: 18px auto 0;
      max-width: 28rem;
      color: var(--muted);
      font-size: 0.96rem;
    }

    .links {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .links a {
      color: var(--accent-strong);
    }

    .orbit-line {
      width: min(100%, 420px);
      height: 1px;
      margin: 26px auto 0;
      background: linear-gradient(90deg, transparent, rgba(150, 178, 255, 0.5), transparent);
    }

    @media (max-width: 720px) {
      .card {
        padding: 24px;
      }

      .mark {
        width: 138px;
        height: 138px;
      }
    }
  </style>

  <div class="container">
    <section class="coming-soon">
      <div class="card panel">
        <div class="badge">Coming soon</div>
        <div class="mark">
          <img src="/orbit-logo.svg" alt="Orbit logo" />
        </div>
        <h1>Orbit is almost here.</h1>
        <p class="lede">
          A personal CRM for remembering people, conversations, and follow-ups without turning
          relationships into busywork.
        </p>
        <div class="stores" aria-label="Store availability">
          <div class="store-pill">Coming soon to Play Store</div>
          <div class="store-pill">Coming soon to App Store</div>
        </div>
        <p class="subcopy">
          Private by default. Thoughtful by design. Built to help you keep the human details close.
        </p>
        <div class="orbit-line"></div>
        <div class="links">
          <a href="/privacy">Privacy policy</a>
          <a href="mailto:vividh999@gmail.com">vividh999@gmail.com</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
